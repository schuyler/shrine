[Unit]
Description=Shrine conductor state machine
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sderle
WorkingDirectory=/home/sderle/shrine
ExecStart=/home/sderle/shrine/.venv/bin/python -m leds.conductor
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
