#N canvas 0 0 900 700 12;
#X text 20 16 mode-table.pd -- tonal source for all voices. Stores one octave of scale intervals.;
#X text 20 34 Input: [r scene-mode] (from state-table.pd) or inlet for manual/debug.;
#X text 20 52 Sends: mode-size (float) \, mode-changed (bang). Array: mode-intervals (size 7).;
#X obj 30 100 r scene-mode;
#X obj 200 100 inlet;
#X obj 30 140 route major-penta minor-penta ionian dorian phrygian lydian mixolydian mixolydian-b6 aeolian;
#X connect 3 0 5 0;
#X connect 4 0 5 0;
#X msg 30 200 \; mode-intervals 0 0 2 4 7 9 0 0 \; mode-size 5 \; mode-changed bang;
#X connect 5 0 6 0;
#X msg 170 200 \; mode-intervals 0 0 3 5 7 10 0 0 \; mode-size 5 \; mode-changed bang;
#X connect 5 1 7 0;
#X msg 340 200 \; mode-intervals 0 0 2 4 5 7 9 11 \; mode-size 7 \; mode-changed bang;
#X connect 5 2 8 0;
#X msg 510 200 \; mode-intervals 0 0 2 3 5 7 9 10 \; mode-size 7 \; mode-changed bang;
#X connect 5 3 9 0;
#X msg 30 300 \; mode-intervals 0 0 1 3 5 7 8 10 \; mode-size 7 \; mode-changed bang;
#X connect 5 4 10 0;
#X msg 200 300 \; mode-intervals 0 0 2 4 6 7 9 11 \; mode-size 7 \; mode-changed bang;
#X connect 5 5 11 0;
#X msg 400 300 \; mode-intervals 0 0 2 4 5 7 9 10 \; mode-size 7 \; mode-changed bang;
#X connect 5 6 12 0;
#X msg 600 300 \; mode-intervals 0 0 2 4 5 7 8 10 \; mode-size 7 \; mode-changed bang;
#X connect 5 7 13 0;
#X msg 600 400 \; mode-intervals 0 0 2 3 5 7 8 10 \; mode-size 7 \; mode-changed bang;
#X connect 5 8 14 0;
#X obj 30 430 loadbang;
#X msg 30 460 major-penta;
#X connect 15 0 16 0;
#X connect 16 0 5 0;
#X obj 30 520 table mode-intervals 7;
