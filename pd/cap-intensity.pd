#N canvas 0 0 450 400 12;
#X text 20 10 cap-intensity.pd -- non-linear 0-1 cap to MIDI CC 11 (expression) for sfont~.;
#X text 20 28 \$1 = gamma (default 1). Values < 1 compress upper range so intensity;
#X text 20 46 stays roughly steady when cap signal dips. Inlet 0: cap (0-1). Outlet 0: ctl msg.;
#X obj 80 80 inlet;
#X obj 80 150 pow;
#X obj 80 185 * 127;
#X obj 80 220 int;
#X obj 80 255 change;
#X msg 80 290 ctl \$1 11 1;
#X obj 80 330 outlet;
#X obj 200 80 loadbang;
#X obj 200 115 expr if(\$1 == 0 \, 1 \, \$1);
#X connect 3 0 4 0;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 8 0 9 0;
#X connect 10 0 11 0;
#X connect 11 0 4 1;
