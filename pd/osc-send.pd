#N canvas 0 0 900 800 12;
#X text 20 16 osc-send.pd --- forward control signals to LED sidecar via OSC.;
#X text 20 34 Target: 255.255.255.255:9000. Protocol: /leds/* namespace.;
#X text 20 52 Buses: cap-0..3 \, heartbeat-0..3 \, flux-0..3 \, beat-ms.;
#X text 20 70 Wiring into main.pd is out of scope -- Schuyler handles that.;
#X text 20 100 --- per-pad cap (0-1) ---;
#X obj 40 130 r cap-0;
#X msg 40 160 0 \$1;
#X obj 40 190 else/osc.format /leds/cap if;
#X obj 40 220 else/osc.send -h 255.255.255.255 -p 9000;
#X obj 240 130 r cap-1;
#X msg 240 160 1 \$1;
#X obj 240 190 else/osc.format /leds/cap if;
#X obj 240 220 else/osc.send -h 255.255.255.255 -p 9000;
#X obj 440 130 r cap-2;
#X msg 440 160 2 \$1;
#X obj 440 190 else/osc.format /leds/cap if;
#X obj 440 220 else/osc.send -h 255.255.255.255 -p 9000;
#X obj 640 130 r cap-3;
#X msg 640 160 3 \$1;
#X obj 640 190 else/osc.format /leds/cap if;
#X obj 640 220 else/osc.send -h 255.255.255.255 -p 9000;
#X text 20 260 --- per-pad heartbeat (Hz) ---;
#X obj 40 290 r heartbeat-0;
#X msg 40 320 0 \$1;
#X obj 40 350 else/osc.format /leds/heartbeat if;
#X obj 40 380 else/osc.send -h 255.255.255.255 -p 9000;
#X obj 240 290 r heartbeat-1;
#X msg 240 320 1 \$1;
#X obj 240 350 else/osc.format /leds/heartbeat if;
#X obj 240 380 else/osc.send -h 255.255.255.255 -p 9000;
#X obj 440 290 r heartbeat-2;
#X msg 440 320 2 \$1;
#X obj 440 350 else/osc.format /leds/heartbeat if;
#X obj 440 380 else/osc.send -h 255.255.255.255 -p 9000;
#X obj 640 290 r heartbeat-3;
#X msg 640 320 3 \$1;
#X obj 640 350 else/osc.format /leds/heartbeat if;
#X obj 640 380 else/osc.send -h 255.255.255.255 -p 9000;
#X text 20 420 --- per-pad flux (0-1) ---;
#X obj 40 450 r flux-0;
#X msg 40 480 0 \$1;
#X obj 40 510 else/osc.format /leds/flux if;
#X obj 40 540 else/osc.send -h 255.255.255.255 -p 9000;
#X obj 240 450 r flux-1;
#X msg 240 480 1 \$1;
#X obj 240 510 else/osc.format /leds/flux if;
#X obj 240 540 else/osc.send -h 255.255.255.255 -p 9000;
#X obj 440 450 r flux-2;
#X msg 440 480 2 \$1;
#X obj 440 510 else/osc.format /leds/flux if;
#X obj 440 540 else/osc.send -h 255.255.255.255 -p 9000;
#X obj 640 450 r flux-3;
#X msg 640 480 3 \$1;
#X obj 640 510 else/osc.format /leds/flux if;
#X obj 640 540 else/osc.send -h 255.255.255.255 -p 9000;
#X text 20 580 --- tempo (BPM from beat-ms) ---;
#X obj 40 610 r beat-ms;
#X obj 40 640 expr 60000 / max($f1 \, 1);
#X obj 40 670 else/osc.format /leds/tempo f;
#X obj 40 700 else/osc.send -h 255.255.255.255 -p 9000;
#X text 20 740 --- program / palette (inlets for manual wiring) ---;
#X obj 400 610 inlet;
#X obj 400 640 else/osc.format /leds/program s;
#X obj 400 670 else/osc.send -h 255.255.255.255 -p 9000;
#X obj 600 610 inlet;
#X obj 600 640 else/osc.format /leds/palette s;
#X obj 600 670 else/osc.send -h 255.255.255.255 -p 9000;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 9 0 10 0;
#X connect 10 0 11 0;
#X connect 11 0 12 0;
#X connect 13 0 14 0;
#X connect 14 0 15 0;
