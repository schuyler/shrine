#N canvas 0 0 720 600 12;
#X text 20 16 refiretest.pd -- headless check for refire.pd (beat-driven re-fire gate).;
#X text 20 34 Fake clock (metro 100 = tick) + grid refire=4 (quarter). Touch at 250ms \, release at 1250ms \, quit at 2000ms.;
#X text 20 52 Prints ADVANCE on every re-fire and MARK RELEASED at release. Expect >=2 advances while held \, none after.;
#X obj 40 110 loadbang;
#X msg 40 150 1;
#X obj 40 190 metro 100;
#X obj 40 240 f;
#X obj 40 290 s tickcount;
#X obj 180 240 + 1;
#X obj 180 280 mod 16;
#X msg 260 150 4;
#X obj 260 190 s refire;
#X obj 420 240 refire;
#X obj 420 300 print ADVANCE;
#X obj 420 110 del 250;
#X msg 420 150 1;
#X obj 560 110 del 1250;
#X obj 560 150 t b b;
#X msg 600 200 0;
#X msg 500 200 RELEASED;
#X obj 500 250 print MARK;
#X obj 260 110 del 2000;
#X msg 260 70 \; pd quit;
#X connect 3 0 4 0;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 6 0 8 0;
#X connect 8 0 9 0;
#X connect 9 0 6 1;
#X connect 3 0 10 0;
#X connect 10 0 11 0;
#X connect 3 0 14 0;
#X connect 14 0 15 0;
#X connect 15 0 12 0;
#X connect 12 0 13 0;
#X connect 3 0 16 0;
#X connect 16 0 17 0;
#X connect 17 0 19 0;
#X connect 17 1 18 0;
#X connect 18 0 12 0;
#X connect 19 0 20 0;
#X connect 3 0 21 0;
#X connect 21 0 22 0;
