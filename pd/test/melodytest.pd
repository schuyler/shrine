#N canvas 40 40 720 520 12;
#X text 20 16 melodytest.pd -- headless check: metro bang -> melodic-voice -> print. Loads mode-table for the scale \, feeds a constant gsr-mag-0 for velocity \, prints each "pitch velocity" pair \, and quits after ~3 s. Run: pd -nogui -noaudio -stderr -path pd pd/test/melodytest.pd;
#X obj 40 110 mode-table;
#X obj 40 220 melodic-voice 0;
#X obj 40 270 print MELODY;
#X obj 300 90 loadbang;
#X obj 300 130 t b b b;
#X msg 300 320 0.7;
#X obj 300 360 s gsr-mag-0;
#X msg 300 230 root 60;
#X obj 300 170 del 200;
#X msg 300 210 1;
#X obj 40 170 metro 250;
#X obj 520 130 del 3200;
#X msg 520 180 0;
#X msg 520 230 \; pd quit;
