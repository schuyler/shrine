#N canvas 0 0 700 460 12;
#X text 20 16 clock.pd -- single global pulse. inlet: BPM (default 60).;
#X text 20 34 Sends: beat (bang/beat)\, bar (bang every 4 beats)\, beat-ms (float).;
#X obj 30 80 inlet;
#X obj 200 80 loadbang;
#X msg 200 110 60;
#X connect 3 0 4 0;
#X obj 30 150 t f;
#X connect 2 0 5 0;
#X connect 4 0 5 0;
#X obj 30 185 expr 60000/$f1;
#X obj 200 185 s beat-ms;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X obj 30 250 metro 1000;
#X connect 6 0 8 1;
#X msg 150 220 1;
#X obj 150 190 loadbang;
#X connect 10 0 9 0;
#X connect 9 0 8 0;
#X obj 30 300 s beat;
#X connect 8 0 11 0;
#X obj 200 300 + 1;
#X obj 200 330 mod 4;
#X connect 8 0 12 0;
#X obj 260 300 f;
#X connect 13 0 14 0;
#X connect 14 0 12 1;
#X obj 200 360 sel 0;
#X connect 13 0 15 0;
#X obj 200 390 s bar;
#X connect 15 0 16 0;
