#N canvas 0 0 760 620 12;
#X text 20 16 clock.pd -- single global pulse \, tick-divider. inlet: BPM (default 60).;
#X text 20 34 Sends: tick (bang/16th) \, beat (bang/quarter) \, bar (bang/4 beats) \, tickcount (0-15) \, beat-ms (float).;
#X text 20 52 One metro at the 16th note; beat/bar/tickcount are integer divisions of it (no phase drift).;
#X obj 30 110 inlet;
#X obj 230 90 loadbang;
#X msg 230 120 60;
#X obj 30 160 t f;
#X obj 30 200 expr 60000/$f1;
#X obj 210 200 s beat-ms;
#X obj 150 250 expr 15000/$f1;
#X obj 30 310 metro 250;
#X obj 230 270 loadbang;
#X msg 230 305 1;
#X obj 450 310 s tick;
#X obj 30 360 f;
#X obj 170 360 + 1;
#X obj 170 400 mod 16;
#X obj 320 430 s tickcount;
#X obj 30 450 mod 4;
#X obj 30 490 sel 0;
#X obj 30 530 s beat;
#X obj 130 490 sel 0;
#X obj 130 530 s bar;
#X connect 3 0 6 0;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 6 0 9 0;
#X connect 7 0 8 0;
#X connect 9 0 10 1;
#X connect 11 0 12 0;
#X connect 12 0 10 0;
#X connect 10 0 14 0;
#X connect 10 0 13 0;
#X connect 14 0 15 0;
#X connect 15 0 16 0;
#X connect 16 0 14 1;
#X connect 14 0 17 0;
#X connect 14 0 18 0;
#X connect 18 0 19 0;
#X connect 19 0 20 0;
#X connect 14 0 21 0;
#X connect 21 0 22 0;
