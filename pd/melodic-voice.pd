#X connect 1 0 4 0;
#X obj 30 130 int;
#X connect 4 0 5 0;
#X obj 30 160 s \$0-range;
#X connect 5 0 6 0;
#X restore 600 155 pd range-update;
#N canvas 0 0 750 350 beat-gate 0;
#X obj 30 30 r beat;
#X obj 30 60 f \$0-counter;
#X connect 0 0 1 0;
#X obj 30 90 + 1;
#X connect 1 0 2 0;
#X obj 30 120 mod 1;
#X connect 2 0 3 0;
