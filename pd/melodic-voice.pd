#N canvas 40 40 820 500 12;
#X text 20 16 melodic-voice.pd -- pitch generator. Inlet 0: bang (advance) or "octave N". Outlet 0: int MIDI pitch.;
#X text 20 48 Common tonic comes from [r shrine-root] (one root for the whole piece) \, transposed per voice: effective root = shrine-root + 12*octave. Scale from mode-intervals / mode-size.;
#X obj 40 100 inlet;
#X obj 40 140 route octave;
#X obj 40 190 t b;
#X obj 40 230 s \$0-step;
#X obj 460 58 r shrine-root;
#X obj 470 140 t b f;
#X obj 470 190 v \$0-base;
#X obj 150 190 t b f;
#X obj 150 240 v \$0-octave;
#X obj 360 190 s \$0-recompute;
#X obj 470 270 r \$0-recompute;
#X obj 470 310 t b b;
#X obj 590 350 * 12;
#X obj 470 390 +;
#X obj 470 430 v \$0-root;
#N canvas 60 60 440 240 init 0;
#X obj 30 30 loadbang;
#X obj 30 70 t b b b b b b;
#X msg 30 120 1;
#X obj 30 160 v \$0-direction;
#X msg 90 120 0;
#X obj 90 160 v \$0-degree;
#X msg 150 120 0;
#X obj 150 160 v \$0-octave;
#X msg 210 120 60;
#X obj 210 160 v \$0-base;
#X msg 270 120 7;
#X obj 270 160 v \$0-range;
#X obj 330 160 s \$0-recompute;
#X connect 0 0 1 0;
#X connect 1 0 12 0;
#X connect 1 1 2 0;
#X connect 1 2 4 0;
#X connect 1 3 6 0;
#X connect 1 4 8 0;
#X connect 1 5 10 0;
#X connect 2 0 3 0;
#X connect 4 0 5 0;
#X connect 6 0 7 0;
#X connect 8 0 9 0;
#X connect 10 0 11 0;
#X restore 560 100 pd init;
#N canvas 60 60 440 260 range 0;
#X text 20 16 range = floor(1.5 * mode-size) degrees (~1.5 octaves).;
#X obj 30 50 r mode-size;
#X obj 30 90 * 1.5;
#X obj 30 130 int;
#X obj 30 170 v \$0-range;
#X connect 1 0 2 0;
#X connect 2 0 3 0;
#X connect 3 0 4 0;
#X restore 560 140 pd range;
#N canvas 60 60 960 660 walk 0;
#X text 20 16 Weighted walk on the scale degree: 70%% step \, 20%% reverse \, 10%% leap of 2 Reflects at [0 \, range) and flips direction.;
#X obj 30 60 r \$0-step;
#X obj 30 100 t b b;
#X obj 220 140 v \$0-degree;
#X obj 30 230 +;
#X obj 30 140 random 100;
#X obj 30 180 moses 70;
#X obj 160 180 moses 90;
#X obj 30 290 t b;
#X obj 30 330 v \$0-direction;
#X obj 30 370 * 1;
#X obj 160 290 t b;
#X obj 160 330 v \$0-direction;
#X obj 160 370 * -1;
#X obj 160 410 t f f;
#X obj 270 450 v \$0-direction;
#X obj 320 290 t b;
#X obj 320 330 v \$0-direction;
#X obj 320 370 * 2;
#N canvas 60 60 780 440 boundary 0;
#X text 20 16 Reflect raw degree into [0 \, range). Flip \$0-direction on a bounce.;
#X obj 30 60 inlet;
#X obj 30 100 t f b;
#X obj 220 140 v \$0-range;
#X obj 220 180 t f f;
#X obj 320 220 - 1;
#X obj 320 260 * 2;
#X obj 30 240 moses 0;
#X obj 30 290 t b f;
#X obj 30 360 * -1;
#X obj 160 290 moses;
#X obj 230 340 t b f;
#X obj 230 400 * -1;
#X obj 160 440 +;
#X obj 30 500 outlet;
#X obj 430 300 v \$0-direction;
#X obj 430 340 * -1;
#X obj 430 380 v \$0-direction;
