#X connect 4 0 3 1;
#X obj 30 150 sel 0;
#X connect 3 0 5 0;
#X obj 30 180 s \$0-note-trigger;
#X connect 5 0 6 0;
#X obj 30 220 s \$0-counter;
#X connect 3 0 7 0;
#X restore 600 190 pd beat-gate;
#N canvas 0 0 400 250 velocity 0;
#X obj 30 30 r gsr-mag-\$1;
#X obj 30 60 * 127;
#X connect 0 0 1 0;
#X obj 30 90 clip 0 127;
#X connect 1 0 2 0;
#X obj 30 120 int;
#X connect 2 0 3 0;
#X obj 30 150 s \$0-velocity;
#X connect 3 0 4 0;
#X restore 600 225 pd velocity;
#N canvas 0 0 750 700 walk 0;
#X text 20 16 Weighted random walk. 70%% step \, 20%% reverse \, 10%% leap.;
#X obj 30 50 r \$0-note-trigger;
#X obj 30 80 t b b;
#X connect 1 0 2 0;
#X obj 30 120 random 100;
#X connect 2 1 3 0;
#X obj 30 150 moses 70;
#X connect 3 0 4 0;
#X obj 150 150 moses 90;
#X connect 4 1 5 0;
#X text 30 190 -- step --;
#X obj 30 210 t b;
#X connect 4 0 7 0;
#X msg 30 240 1;
#X connect 7 0 8 0;
#X obj 30 270 *;
#X connect 8 0 9 0;
#X obj 130 270 r \$0-direction;
#X connect 10 0 9 1;
#X text 200 190 -- reverse --;
#X obj 200 210 t b;
#X connect 5 0 12 0;
#X obj 200 240 r \$0-direction;
#X obj 200 270 * -1;
#X connect 13 0 14 0;
#X obj 200 300 t f f;
#X connect 14 0 15 0;
#X obj 200 330 s \$0-direction;
#X connect 15 0 16 0;
#X msg 330 330 1;
#X connect 12 0 17 0;
#X obj 330 360 *;
#X connect 17 0 18 0;
#X connect 15 1 18 1;
#X text 400 190 -- leap --;
#X obj 400 210 t b;
#X connect 5 1 20 0;
#X msg 400 240 2;
#X connect 20 0 21 0;
#X obj 400 270 *;
#X connect 21 0 22 0;
#X obj 500 270 r \$0-direction;
#X connect 23 0 22 1;
#X text 30 400 -- add delta to degree --;
#X obj 30 430 f \$0-degree;
#X connect 2 0 25 0;
#X obj 30 460 +;
#X connect 25 0 26 0;
#X connect 9 0 26 1;
#X connect 18 0 26 1;
#X connect 22 0 26 1;
