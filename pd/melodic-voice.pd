#X msg 500 200 -1;
#X connect 16 1 17 0;
#X obj 500 230 s \$0-direction;
#X connect 17 0 18 0;
#X connect 16 0 7 0;
#X restore 30 500 pd boundary;
#X connect 26 0 27 0;
#X obj 30 540 t f f;
#X connect 27 0 28 0;
#X obj 30 570 s \$0-degree;
#X connect 28 0 29 0;
#X obj 200 570 s \$0-pitch-trigger;
#X connect 28 1 30 0;
#X restore 600 260 pd walk;
#N canvas 0 0 800 500 pitch 0;
#X text 20 16 degree -> MIDI pitch via mode-intervals table.;
#X obj 30 50 r \$0-pitch-trigger;
#X obj 30 80 t f f;
#X connect 1 0 2 0;
#X obj 30 120 r mode-size;
#X obj 30 150 mod 7;
#X connect 2 0 4 0;
#X connect 3 0 4 1;
#X obj 30 180 tabread mode-intervals;
#X connect 4 0 5 0;
#X obj 300 120 r mode-size;
#X obj 300 150 div 7;
#X connect 2 1 7 0;
#X connect 6 0 7 1;
#X obj 300 180 * 12;
#X connect 7 0 8 0;
#X obj 30 240 +;
#X connect 5 0 9 0;
#X connect 8 0 9 1;
#X obj 30 280 r \$0-root;
#X obj 30 310 +;
#X connect 9 0 11 0;
#X connect 10 0 11 1;
#X obj 30 350 s \$0-pitch;
#X connect 11 0 12 0;
#X restore 600 295 pd pitch;
#N canvas 0 0 800 500 output 0;
#X text 20 16 Pitch arrival triggers dispatch. Note-off before note-on.;
#X obj 30 50 r \$0-pitch;
#X obj 30 80 t b f;
#X connect 1 0 2 0;
#X obj 250 80 f \$0-new-pitch;
#X connect 2 1 3 1;
#X obj 30 120 f \$0-velocity;
#X connect 2 0 4 0;
#X obj 30 150 moses 5;
#X connect 4 0 5 0;
#X obj 30 190 t b;
#X connect 5 0 6 0;
#X obj 250 190 t b b;
#X connect 5 1 7 0;
#N canvas 0 0 500 400 do-note-off 0;
#X text 20 16 If playing \, send note-off for last pitch and set playing=0.;
#X obj 30 50 inlet;
#X obj 30 80 f \$0-playing;
#X connect 1 0 2 0;
#X obj 30 110 sel 1;
#X connect 2 0 3 0;
#X obj 30 140 t b b;
#X connect 3 0 4 0;
#X obj 30 180 f \$0-last-pitch;
#X connect 4 1 5 0;
#X obj 200 180 r \$0-channel;
#X obj 30 210 pack f 0 f;
#X connect 5 0 7 0;
#X connect 6 0 7 2;
#X obj 30 240 list prepend note;
#X connect 7 0 8 0;
#X obj 30 270 list trim;
#X connect 8 0 9 0;
#X obj 30 300 s voice-midi;
#X connect 9 0 10 0;
#X msg 250 180 0;
#X connect 4 0 11 0;
#X obj 250 210 s \$0-playing;
#X connect 11 0 12 0;
#X restore 30 230 pd do-note-off;
#X connect 6 0 8 0;
#X connect 7 1 8 0;
#N canvas 0 0 550 450 do-note-on 0;
#X text 20 16 Send note-on for new pitch. Update last-pitch \, set playing=1.;
#X obj 30 50 inlet;
#X obj 30 80 t b b b b;
#X connect 1 0 2 0;
#X obj 400 120 f \$0-channel;
#X connect 2 3 3 0;
#X obj 280 120 f \$0-velocity;
#X connect 2 2 4 0;
#X obj 160 120 f \$0-new-pitch;
#X connect 2 1 5 0;
#X obj 30 160 pack f f f;
#X connect 5 0 6 0;
#X connect 4 0 6 1;
#X connect 3 0 6 2;
#X obj 30 190 list prepend note;
#X connect 6 0 7 0;
#X obj 30 220 list trim;
#X connect 7 0 8 0;
#X obj 30 250 s voice-midi;
#X connect 8 0 9 0;
#X obj 30 300 f \$0-new-pitch;
