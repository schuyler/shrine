#N canvas 60 60 940 660 voice 0;
#X text 20 16 On emit: degree -> MIDI pitch via mode-intervals \, then note-off the last pitch and note-on the new one as pitch+velocity pairs.;
#X obj 30 60 r \$0-emit;
#X obj 30 100 t b b;
#X obj 30 140 v \$0-root;
#X obj 150 140 v \$0-degree;
#X obj 150 180 t f f;
#X obj 150 230 mod 5;
#X obj 150 270 tabread mode-intervals;
#X obj 280 230 div 5;
#X obj 280 270 * 12;
#X obj 150 320 +;
#X obj 150 370 +;
#X obj 150 410 t b f;
#X obj 320 410 v \$0-newpitch;
#X obj 540 140 r mode-size;
#X obj 540 180 t f f;
#X obj 150 460 v \$0-velocity;
#X obj 150 500 moses 5;
#X obj 150 550 t b;
#X obj 280 550 t b b;
#N canvas 60 60 540 400 do-note-off 0;
#X text 20 16 If playing \, emit "lastpitch 0" (note-off) and clear playing.;
#X obj 30 60 inlet;
#X obj 30 100 v \$0-playing;
#X obj 30 140 sel 1;
#X obj 30 180 t b b;
#X obj 30 220 v \$0-lastpitch;
#X obj 30 260 pack f 0;
#X obj 30 300 outlet;
#X msg 150 220 0;
#X obj 150 260 v \$0-playing;
