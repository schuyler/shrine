#N canvas 40 40 820 600 12;
#X text 20 16 melodic-voice.pd -- one melody-line generator per voice. Inlet 0: bang to advance a note (also accepts an "octave N" message). Inlet 1: velocity/intensity 0-1 (from cap-trigger). Emits pitch+velocity pairs to a texture Note inlet.;
#X text 20 58 Common tonic comes from [r shrine-root] (one root for the whole piece)\, transposed per voice: effective root = shrine-root + 12*octave. Scale from mode-intervals / mode-size.;
#X obj 40 110 inlet;
#X obj 220 110 inlet;
#X obj 40 150 route octave;
#X obj 40 200 t b;
#X obj 40 240 s \$0-step;
#X obj 220 150 * 127;
#X obj 220 190 clip 0 127;
#X obj 220 230 int;
#X obj 220 270 v \$0-velocity;
#X obj 470 110 r shrine-root;
#X obj 470 150 t b f;
#X obj 470 200 v \$0-base;
#X obj 150 200 t b f;
#X obj 150 250 v \$0-octave;
#X obj 360 200 s \$0-recompute;
#X obj 470 280 r \$0-recompute;
#X obj 470 320 t b b;
#X obj 590 360 * 12;
#X obj 470 400 +;
#X obj 470 440 v \$0-root;
#N canvas 60 60 540 380 init 0;
#X obj 30 30 loadbang;
#X obj 30 70 t b b b b b b b b;
#X msg 30 120 1;
#X obj 30 160 v \$0-direction;
#X msg 90 120 0;
#X obj 90 160 v \$0-degree;
#X msg 150 120 0;
#X obj 150 160 v \$0-playing;
#X msg 210 120 0;
#X obj 210 160 v \$0-lastpitch;
#X msg 270 120 0;
#X obj 270 160 v \$0-octave;
#X msg 330 120 60;
#X obj 330 160 v \$0-base;
#X msg 390 120 7;
#X obj 390 160 v \$0-range;
#X obj 450 160 s \$0-recompute;
#X connect 0 0 1 0;
#X connect 1 1 2 0;
#X connect 2 0 3 0;
#X connect 1 2 4 0;
#X connect 4 0 5 0;
#X connect 1 3 6 0;
