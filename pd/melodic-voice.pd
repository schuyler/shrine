#N canvas 0 0 1000 900 12;
#X text 20 16 melodic-voice.pd -- one contrapuntal melody voice per GSR pair.;
#X text 20 34 Args: \$1=pair index (0-5) \, \$2=MIDI root \, \$3=MIDI channel.;
#X text 20 52 Messages: duration N (beats between notes \, default 1) \, root N (MIDI root).;
#X text 20 70 Output: note <pitch> <velocity> <channel> on [s voice-midi].;
#X obj 30 120 inlet;
#X obj 30 155 route duration root;
#X connect 4 0 5 0;
#X obj 30 190 f \$0-duration;
#X connect 5 0 6 0;
#X obj 200 190 f \$0-root;
#X connect 5 1 7 0;
#N canvas 0 0 650 400 init 0;
#X obj 30 30 loadbang;
#X obj 30 60 t b b b b b b;
#X connect 0 0 1 0;
#X msg 30 100 1;
#X connect 1 0 2 0;
#X obj 30 130 s \$0-duration;
#X connect 2 0 3 0;
#X msg 120 100 \$2;
#X connect 1 1 4 0;
#X obj 120 130 s \$0-root;
#X connect 4 0 5 0;
#X msg 210 100 \$3;
#X connect 1 2 6 0;
#X obj 210 130 s \$0-channel;
#X connect 6 0 7 0;
#X msg 300 100 1;
#X connect 1 3 8 0;
#X obj 300 130 s \$0-direction;
#X connect 8 0 9 0;
#X msg 390 100 0;
#X connect 1 4 10 0;
#X obj 390 130 s \$0-playing;
#X connect 10 0 11 0;
#X msg 480 100 0;
#X connect 1 5 12 0;
#X obj 480 130 s \$0-degree;
#X connect 12 0 13 0;
#X restore 600 120 pd init;
#N canvas 0 0 600 300 range-update 0;
#X obj 30 30 r mode-size;
#X obj 30 60 f;
#X connect 0 0 1 0;
#X obj 200 30 r mode-changed;
#X obj 200 60 t b;
#X connect 2 0 3 0;
#X connect 3 0 1 0;
